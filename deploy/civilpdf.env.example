# CivilPDF-DX environment variables
# Copy to civilpdf.env and fill in real values.
# NEVER commit civilpdf.env to git.

# ── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql://civildx:CHANGE_ME@localhost:5432/civildx

# ── Security ────────────────────────────────────────────────
SECRET_KEY=CHANGE_ME_generate_with__openssl_rand_-hex_32

# ── CORS ────────────────────────────────────────────────────
# JSON array of allowed origins
CORS_ORIGINS=["http://localhost:3000","https://your-domain.example.com"]

# ── File uploads ────────────────────────────────────────────
UPLOAD_DIR=/var/lib/civildx/uploads

# ── AI (optional) ───────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Microsoft 365 (optional) ────────────────────────────────
# M365_TENANT_ID=
# M365_CLIENT_ID=
# M365_CLIENT_SECRET=
