# Database
DATABASE_URL=postgresql://civilpdf:password@localhost:5432/civilpdf
REDIS_URL=redis://localhost:6379/0

# Authentication (Entra ID)
AZURE_CLIENT_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_SECRET=

# HENNGE ONE (optional, for production)
HENNGE_SSO_ENDPOINT=

# AI (Claude API)
ANTHROPIC_API_KEY=

# OCR
TESSERACT_PATH=/usr/bin/tesseract

# PDF/A Validation
VERAPDF_PATH=/usr/bin/verapdf

# App Settings
APP_ENV=development
APP_PORT=8000
APP_SECRET_KEY=change-this-in-production

# Logging
LOG_LEVEL=INFO
